{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "angular_template",
      "camelcase": "AngularTemplate",
      "scope": "source.angular-template",
      "path": ".",
      "file-types": ["ng.html"],
      "injection-regex": "angular"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Custom tree-sitter grammar for Angular component templates (HTML + bindings + control flow + expression sublanguage).",
    "authors": [{ "name": "sprig" }]
  }
}
