{
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "lib": [
      "deno.ns",
      "dom",
      "dom.iterable",
      "dom.asynciterable",
      "esnext"
    ]
  },
  "workspace": [
    "./cli",
    "./server",
    "./app"
  ],
  "imports": {
    "@mrg-keystone/sprig": "./framework/.sprig/core.ts",
    "@mrg-keystone/sprig/keep": "./packages/keep/mod.ts",
    "@preact/signals-core": "npm:@preact/signals-core@^1.8.0",
    "web-tree-sitter": "npm:web-tree-sitter@^0.25",
    "@std/path": "jsr:@std/path@^1",
    "@std/fs": "jsr:@std/fs@^1",
    "@std/assert": "jsr:@std/assert@^1"
  },
  "tasks": {
    "sprig": "deno run -A framework/cli.ts",
    "install": "deno run -A jsr:@mrg-keystone/sprig/cli install",
    "install:dev": "deno run -A framework/cli.ts install --dev",
    "dev": "deno run -A framework/cli.ts dev app",
    "build": "deno run -A framework/cli.ts build app",
    "start": "deno serve -A --unstable-kv serve.ts",
    "sync:rune": "deno run -A scripts/sync-rune.ts",
    "sync:agent-guardrail": "deno run -A scripts/sync-agent-guardrail.ts",
    "check:agent-guardrail": "deno run -A scripts/sync-agent-guardrail.ts --check"
  },
  "name": "@mrg-keystone/sprig",
  "version": "0.20.36",
  "license": "MIT",
  "exports": {
    ".": "./framework/.sprig/core.ts",
    "./keep": "./packages/keep/mod.ts",
    "./cli": "./framework/cli.ts"
  },
  "publish": {
    "include": [
      "LICENSE",
      "deno.json",
      "framework/.sprig/annotate.ts",
      "framework/.sprig/annotate-client.js",
      "framework/.sprig/auth.ts",
      "framework/.sprig/compiler/build.ts",
      "framework/.sprig/compiler/dev.ts",
      "framework/.sprig/compiler/expr.ts",
      "framework/.sprig/compiler/grammar.bin",
      "framework/.sprig/compiler/hash.ts",
      "framework/.sprig/compiler/hmr.ts",
      "framework/.sprig/compiler/hydrate.ts",
      "framework/.sprig/compiler/island.ts",
      "framework/.sprig/compiler/lifecycle.ts",
      "framework/.sprig/compiler/mod.ts",
      "framework/.sprig/compiler/node.ts",
      "framework/.sprig/compiler/parse.ts",
      "framework/.sprig/compiler/perf.ts",
      "framework/.sprig/compiler/render.ts",
      "framework/.sprig/compiler/scope.ts",
      "framework/.sprig/compiler/serialize.ts",
      "framework/.sprig/core.ts",
      "framework/.sprig/install.ts",
      "framework/.sprig/skills.ts",
      "framework/.sprig/spec-root.ts",
      "framework/cli.ts",
      "packages/keep/mod.ts",
      "packages/keep/vendor/apexcharts.js"
    ]
  },
  "git": {
    "repo": "https://github.com/mrg-keystone/sprig",
    "commit": "34556dc10529e98aec45490ef41dfb7e8d98dee4",
    "branch": "main",
    "buildTime": "2026-07-06T20:08:51.515Z"
  }
}
